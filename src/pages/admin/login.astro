---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCurrentSession, isAdminAllowed } from "../../lib/auth";

export const prerender = false;

const session = await getCurrentSession(Astro.cookies);
const error = Astro.url.searchParams.get("error") ?? "";
const isAllowed = session ? isAdminAllowed(session) : false;

if (session && isAllowed) {
  return Astro.redirect("/admin/", 302);
}

const errorMessage =
  error === "not_allowed" || (session && !isAllowed)
    ? "This account signed in successfully, but it is not approved for admin access. Ask the site owner to add your email to APPWRITE_ADMIN_EMAILS or your user ID to APPWRITE_ADMIN_USER_IDS."
    : error === "invalid_credentials"
      ? "Invalid email or password for this Appwrite project. If this account was created with an OAuth provider, it may not have a password yet."
      : error === "project_mismatch"
        ? "The site cannot authenticate against the configured Appwrite project. Verify APPWRITE_URL and APPWRITE_PROJECT_ID in production env vars."
        : error === "rate_limited"
          ? "Too many login attempts. Wait a moment, then try again."
          : error === "missing_credentials"
            ? "Please enter both email and password."
            : error === "server_error" || error === "auth_failed"
              ? "Sign in failed due to a server-side error. Please try again, then check server logs if it continues."
    : null;
---

<BaseLayout title="Post Maker Login | Stephen M. Bird" pageClass="admin-login" showSidebar={false}>
  <div class="panel">
    <h1>Post Maker Login</h1>
    <p>Sign in with your Appwrite email and password to manage posts, archive old stories, and publish new ones.</p>
    <p>If admin allow-list env vars are set, only those approved Appwrite accounts can enter.</p>

    {errorMessage ? <p class="admin-notice">{errorMessage}</p> : null}

    <form class="card auth-card" method="post" action="/api/admin/login">
      <div class="form-grid">
        <label>
          Email
          <input type="email" name="email" required />
        </label>
        <label>
          Password
          <input type="password" name="password" required />
        </label>
        <button type="submit">Sign In</button>
      </div>
    </form>
  </div>
</BaseLayout>


