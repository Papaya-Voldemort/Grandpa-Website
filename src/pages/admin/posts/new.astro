---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RichTextEditor from "../../../components/RichTextEditor";
import { requireAdminSession } from "../../../lib/auth";
import { categories } from "../../../lib/categories";

export const prerender = false;

const session = await requireAdminSession(Astro.cookies);
if (!session) {
  return Response.redirect(new URL("/admin/login/", Astro.url), 302);
}
---

<BaseLayout title="New Post | Stephen M. Bird" pageClass="admin-editor" showSidebar={false}>
  <div class="panel">
    <h1>New Post</h1>
    <form class="form-grid card" method="post" action="/api/posts/save">
      <label>
        Title
        <input type="text" name="title" required />
      </label>

      <label>
        Slug
        <input type="text" name="slug" placeholder="auto-generated from title if blank" />
      </label>

      <label>
        Category
        <select name="category" required>
          <option value="">Choose a category</option>
          {categories.map((category) => <option value={category.slug}>{category.label}</option>)}
        </select>
      </label>

      <label>
        Category label
        <input type="text" name="categoryLabel" placeholder="Optional override for display text" />
      </label>

      <label>
        Excerpt
        <textarea name="excerpt" placeholder="Short summary shown in listings."></textarea>
      </label>

      <label>
        Cover image URL
        <input type="url" name="coverImage" placeholder="/images/example.jpg or https://..." />
      </label>

      <label>
        Status
        <select name="status">
          <option value="draft">Draft</option>
          <option value="published">Published</option>
          <option value="archived">Archived</option>
        </select>
      </label>

      <label>
        Legacy source path
        <input type="text" name="legacySourcePath" placeholder="public_html/library/..." />
      </label>

      <label>
        Legacy URL
        <input type="url" name="legacyUrl" placeholder="https://stephenmbird.com/library/..." />
      </label>

      <label>
        Sort order
        <input type="number" name="sortOrder" value="0" />
      </label>

      <label>
        Published at
        <input type="datetime-local" name="publishedAt" />
      </label>

      <label>
        Archived at
        <input type="datetime-local" name="archivedAt" />
      </label>

      <div>
        <h2>Content</h2>
        <RichTextEditor client:load initialContent="<p>Write the post here.</p>" />
      </div>

      <button type="submit">Save Post</button>
    </form>
  </div>
</BaseLayout>
