---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireAdminSession } from "../../lib/auth";
import { getAllIncludingArchived } from "../../lib/posts-server";

export const prerender = false;

const session = await requireAdminSession(Astro.cookies);
if (!session) {
  return Response.redirect(new URL("/admin/login/", Astro.url), 302);
}

const posts = await getAllIncludingArchived();
---

<BaseLayout title="Post Maker | Stephen M. Bird" pageClass="admin-home" showSidebar={false}>
  <div class="panel">
    <h1>Post Maker</h1>
    <p class="admin-notice">
      Signed in as <strong>{session.email ?? session.userId}</strong>. Use this dashboard to create, edit, archive, or delete posts.
    </p>

    <div class="admin-grid">
      <div class="card">
        <p><a class="action-button" href="/admin/posts/new/">Write a New Post</a></p>
        <form method="post" action="/api/admin/logout">
          <button type="submit">Sign Out</button>
        </form>
      </div>

      <div class="admin-list">
        {posts.map((post) => (
          <article class="card">
            <h3>
              <a href={`/admin/posts/${post.slug}/`}>{post.title}</a>
            </h3>
            <p class="meta">
              <span class={`status-pill is-${post.status}`}>{post.status}</span> {post.categoryLabel || post.category}
            </p>
            <p>{post.excerpt}</p>
            <p>
              <a href={`/library/${post.category}/${post.slug}/`}>View Public Page</a>
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
