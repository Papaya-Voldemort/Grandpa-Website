---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../lib/posts-server";

const posts = await getPublishedPosts();
const hero = posts[0];
const left = posts[1];
const middle = posts[2];
const right = posts[3];
---

<BaseLayout title="Stephen M. Bird | Prayers | Miracles | Family | Marriage | Happiness" containerId="home-page">
  <section class="article top">
    <div class="topImage">
      <img src={hero?.coverImage ?? "/images/cornucopia.jpg"} alt={hero?.title ?? "Every Day Is Thanksgiving"} />
    </div>
    <div class="topContent">
      <h1>{hero?.title ?? "Every Day Is Thanksgiving"}</h1>
      <h3>
        {hero?.categoryLabel ?? "Featured Story"}
        {hero?.publishedAt ? ` · ${new Date(hero.publishedAt).toLocaleDateString("en-US")}` : ""}
      </h3>
      <p>{hero?.excerpt ?? "Faith, gratitude, family, and miracles in everyday life."}</p>
      {hero ? (
        <p><a href={`/library/${hero.category}/${hero.slug}/`}>Read More &raquo;</a></p>
      ) : null}
    </div>
  </section>

  <div class="clear"></div>

  <section class="article left">
    {left ? (
      <>
        <h2><a href={`/library/${left.category}/${left.slug}/`}>{left.title}</a></h2>
        <h3>{left.categoryLabel}{left.publishedAt ? ` · ${new Date(left.publishedAt).toLocaleDateString("en-US")}` : ""}</h3>
        <p>{left.excerpt}</p>
        <p><a href={`/library/${left.category}/${left.slug}/`}>Read More &raquo;</a></p>
      </>
    ) : null}
  </section>

  <section class="article middle">
    {middle ? (
      <>
        <h2><a href={`/library/${middle.category}/${middle.slug}/`}>{middle.title}</a></h2>
        <h3>{middle.categoryLabel}{middle.publishedAt ? ` · ${new Date(middle.publishedAt).toLocaleDateString("en-US")}` : ""}</h3>
        <p>{middle.excerpt}</p>
        <p><a href={`/library/${middle.category}/${middle.slug}/`}>Read More &raquo;</a></p>
      </>
    ) : null}
  </section>

  <section class="article right">
    {right ? (
      <>
        <h2><a href={`/library/${right.category}/${right.slug}/`}>{right.title}</a></h2>
        <h3>{right.categoryLabel}{right.publishedAt ? ` · ${new Date(right.publishedAt).toLocaleDateString("en-US")}` : ""}</h3>
        <p>{right.excerpt}</p>
        <p><a href={`/library/${right.category}/${right.slug}/`}>Read More &raquo;</a></p>
      </>
    ) : null}
  </section>

  <div class="clear"></div>

  <div class="browseButton">
    <a href="/library/archives/" class="browseMore">Browse More Articles &raquo;</a>
  </div>
</BaseLayout>
