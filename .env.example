APPWRITE_URL=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_KEY=your_server_side_api_key
APPWRITE_ADMIN_EMAILS=grandpa@example.com

# Admin authentication (env-only)
ADMIN_AUTH_EMAIL=admin@example.com
ADMIN_AUTH_PASSWORD=change_me
ADMIN_AUTH_SESSION_SECRET=replace_with_a_long_random_secret
ADMIN_AUTH_NAME=Admin
ADMIN_AUTH_COOKIE_NAME=admin_session
ADMIN_AUTH_SESSION_TTL_HOURS=12
