{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/posts/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/posts/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/media/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/posts/archive/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/posts/delete/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/posts/save/?$",
			"dest": "_render"
		},
		{
			"src": "^/default/?$",
			"dest": "_render"
		},
		{
			"src": "^/library/archives/?$",
			"dest": "_render"
		},
		{
			"src": "^/library/([^/]+?)/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/library/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/library(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/post-maker/?$",
			"dest": "_render"
		},
		{
			"src": "^/prayersthatbringmiracles/default/?$",
			"dest": "_render"
		},
		{
			"src": "^/prayersthatbringmiracles/?$",
			"dest": "_render"
		},
		{
			"src": "^/search/?$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}