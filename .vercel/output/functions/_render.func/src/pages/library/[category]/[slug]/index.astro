---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PostCard from "../../../../components/PostCard.astro";
import { getCategoryInfo } from "../../../../lib/categories";
import { getCurrentSession } from "../../../../lib/auth";
import {
  getCanonicalPostPath,
  getPostByCategoryAndSlug,
  getPostBySlug,
  getPostsForCategory,
} from "../../../../lib/posts-server";

export const prerender = false;

const category = Astro.params.category ?? "";
const slug = Astro.params.slug ?? "";
const exactPost = await getPostByCategoryAndSlug(category, slug);
const nestedCategory = `${category}/${slug}`;
const nestedPosts = exactPost ? [] : await getPostsForCategory(nestedCategory);
const nestedInfo = getCategoryInfo(nestedCategory);

const session = await getCurrentSession(Astro.cookies);

if (!exactPost && nestedPosts.length === 0) {
  const fallback = await getPostBySlug(slug);
  if (fallback) {
    return Astro.redirect(getCanonicalPostPath(fallback), 301);
  }

  return new Response("Not found", { status: 404 });
}

const info = getCategoryInfo(category);
---

{exactPost ? (
  <BaseLayout title={`${exactPost.title} | Stephen M. Bird`} description={exactPost.excerpt} pageClass={`post-${slug}`}>
    {session && exactPost.$id && (
      <div style="margin: 1rem 0; padding: 1rem; background-color: #fef4dd; border: 1px solid #fbb51a; border-radius: 4px; display: flex; justify-content: space-between; align-items: center;">
        <strong style="color: #252161;">You are logged in as Admin.</strong>
        <a href={`/admin/posts/${exactPost.$id}`} class="admin-callout">EDIT THIS POST</a>
      </div>
    )}
    <div class="panel legacy-body">
      <img src={info.headerImage} alt={info.label} />
      <h1>{exactPost.title}</h1>
      <p class="meta">{info.label}{exactPost.publishedAt ? ` · ${new Date(exactPost.publishedAt).toLocaleDateString("en-US")}` : ""}</p>
      <article class="article-body" set:html={exactPost.contentHtml} />
    </div>
  </BaseLayout>
) : (
  <BaseLayout title={`${nestedInfo.label} | Stephen M. Bird`} description={nestedInfo.intro} pageClass={`category-${nestedCategory}`}>
    <div class="panel">
      <img src={nestedInfo.headerImage} alt={nestedInfo.label} />
      <h1>{nestedInfo.label}</h1>
      <p>{nestedInfo.intro}</p>

      <section class="post-grid">
        {nestedPosts.map((nestedPost) => <PostCard post={nestedPost} />)}
      </section>
    </div>
  </BaseLayout>
)}
