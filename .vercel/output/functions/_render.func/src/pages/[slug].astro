---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageBySlug } from "../lib/posts-server";
import { getCurrentSession } from "../lib/auth";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const page = await getPageBySlug(slug);

if (!page) {
  return new Response("Not found", { status: 404 });
}
const session = await getCurrentSession(Astro.cookies);
---

<BaseLayout title={`${page.title} | Stephen M. Bird`} description={page.title}>
  {session && page.$id && (
    <div style="margin-bottom: 2rem; padding: 1rem; background-color: #fef4dd; border: 1px solid #fbb51a; border-radius: 4px; display: flex; justify-content: space-between; align-items: center;">
      <strong style="color: #252161;">You are logged in as Admin.</strong>
      <a href={`/admin/posts/${page.$id}`} class="admin-callout">EDIT THIS POST</a>
    </div>
  )}
  <div class="legacy-body" set:html={page.contentHtml} />
</BaseLayout>

